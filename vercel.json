{
  "buildCommand": "cd apps/coreweb && npm run build",
  "outputDirectory": "apps/coreweb/dist",
  "redirects": [
    {
      "source": "/tr",
      "has": [
        {
          "type": "host",
          "value": "www.coreweb.tr"
        }
      ],
      "destination": "https://www.coreweb.tr",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
