rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── PUBLIC: Site Mappings (domain → tenant resolution) ──────────────────
    match /siteMappings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── PUBLIC: Tenant Content (products, blogs, navigation, settings) ───────
    match /tenants/{tenantId} {
      // Tenant document itself — sadece authenticated okuyabilir
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Products — public read (müşteri sitesi için)
      match /products/{productId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Blogs — public read
      match /blogs/{blogId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // News — public read
      match /news/{newsId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Navigation — public read
      match /navigation/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Sliders — public read
      match /sliders/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Settings / Company info — public read
      match /settings/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Projects — public read
      match /projects/{projectId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Collections (koleksiyonlar) — public read
      match /collections/{collectionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Diğer tüm sub-collection'lar — authenticated
      match /{subcollection}/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ─── PROTECTED: Admin / Panel verileri ───────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /adminSettings/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── DEFAULT: Her şeyi kapat ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
